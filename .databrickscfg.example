# Copy to ~/.databrickscfg. Use OAuth (no token):
#   databricks auth login --profile tko
# Project workspace: https://fe-sandbox-serverless-sandbox-x7ar8s.cloud.databricks.com

[DEFAULT]
host = https://fe-sandbox-serverless-sandbox-x7ar8s.cloud.databricks.com

[tko]
host = https://fe-sandbox-serverless-sandbox-x7ar8s.cloud.databricks.com
# Use serverless compute (no cluster required). Omit cluster_id.
serverless_compute_id = auto
